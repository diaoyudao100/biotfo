{
  "name": "@biotfo/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute biotfo-db --local --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute biotfo-db --local --file=src/db/seed.sql"
  },
  "dependencies": {
    "@biotfo/shared": "*",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.109.0"
  }
}
